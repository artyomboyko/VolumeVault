{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "docker",
                "run",
                "--rm",
                "-i",
                "-v",
                "$PWD:/app",
                "-w",
                "/app",
                "composer:2",
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    }
}
