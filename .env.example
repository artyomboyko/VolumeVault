APP_NAME=VolumeVault
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
# Set to your reverse proxy IP/CIDR when running behind HTTPS termination.
TRUSTED_PROXIES=
# Comma-separated host path prefixes allowed for host-path backup sources AND
# local backup destinations (both bind-mount host paths into the backup
# container). Fail-closed: when left empty, host-path sources and local
# destinations are refused. Set the prefixes you intend to back up to/from,
# e.g. VOLUMEVAULT_HOST_PATH_ALLOWLIST=/srv/data,/mnt/backups
VOLUMEVAULT_HOST_PATH_ALLOWLIST=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
DB_DATABASE=/app/storage/database/database.sqlite
# DB_USERNAME=root
# DB_PASSWORD=

# Default lifetime (in minutes) for API tokens that have no explicit expiry.
# Caps the blast radius of a leaked token; even "permanent" tokens stop
# working after this window. Defaults to 60 days (86400). A per-token expiry
# can only shorten this. Set to null to allow non-expiring tokens.
# SANCTUM_TOKEN_EXPIRATION=86400

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Enable when serving over HTTPS. The cookie is not sent over plain HTTP,
# so leaving this on for an HTTP-only setup will break login.
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
